# LLM Provider: single provider (ollama, anthropic, groq) or fallback chain (comma-separated)
LLM_PROVIDER=ollama,groq,anthropic

# Ollama settings (if using local LLM)
OLLAMA_URL=http://192.168.x.x:11434
# If true, brain uses the model currently loaded on Ollama server (/api/ps)
OLLAMA_AUTO_MODEL=true
# Fallback model when no model is currently loaded
OLLAMA_MODEL=qwen2.5:14b
# How often to refresh active model selection (seconds)
OLLAMA_MODEL_REFRESH_SECONDS=5

# Anthropic settings (if using Claude)
ANTHROPIC_API_KEY=sk-ant-api03-xxx
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Groq settings (if using Groq)
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=llama-3.1-70b-versatile

# MQTT broker for timer notifications
MQTT_BROKER=192.168.x.x
MQTT_PORT=1883

# TimescaleDB for sensor data
TIMESCALEDB_HOST=192.168.x.x
TIMESCALEDB_PORT=5433
TIMESCALEDB_DATABASE=sensors
TIMESCALEDB_USER=telegraf
TIMESCALEDB_PASSWORD=replace-me

# Prometheus for system metrics
PROMETHEUS_URL=http://192.168.x.x:9090

# SearXNG for web search
SEARXNG_URL=http://192.168.x.x:8089

# Optional location override for weather
LOCATION_CITY=Pembroke
LOCATION_REGION=Ontario
LOCATION_COUNTRY=Canada
LOCATION_TIMEZONE=Eastern Time
LOCATION_LAT=45.8167
LOCATION_LON=-77.1167
